{
  "name": "hookdoctor",
  "version": "0.1.0",
  "description": "Read-only audits for Git hooks, package scripts, and CI commands.",
  "type": "module",
  "main": "./src/index.js",
  "bin": {
    "hookdoctor": "./src/cli.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "fixtures",
    "examples",
    "docs/tutorials",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "test": "node --test",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run build && npm run smoke && npm run package:smoke",
    "build": "node --check src/cli.js && node --check src/index.js",
    "smoke": "node src/cli.js scan fixtures/warn --format json >/tmp/hookdoctor-smoke.json"
  },
  "keywords": [
    "git-hooks",
    "husky",
    "ci",
    "lint"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/hookdoctor.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/hookdoctor/issues"
  },
  "homepage": "https://github.com/rogerchappel/hookdoctor#readme"
}
