{
  "name": "hookdoctor",
  "version": "0.1.0",
  "description": "Read-only audits for Git hooks, package scripts, and CI commands.",
  "type": "module",
  "main": "./src/index.js",
  "bin": {
    "hookdoctor": "./src/cli.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "fixtures",
    "README.md"
  ],
  "scripts": {
    "test": "node --test",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run package:smoke"
  },
  "keywords": [
    "git-hooks",
    "husky",
    "ci",
    "lint"
  ],
  "author": "",
  "license": "MIT"
}
